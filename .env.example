# Copy to .env and fill in real values. NEVER commit .env.
# Generate a key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-50-char-random-secret

# Keep DEBUG off everywhere except local development.
DJANGO_DEBUG=True

DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Local HTTP development cannot use Secure cookies; set False for localhost ONLY.
# This flag is ignored (forced True) whenever DJANGO_DEBUG is off.
COOKIE_SECURE=False

# Force HTTPS redirects in production (ignored in DEBUG).
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# Login lockout policy.
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300

# Comma-separated allowlist of hosts the server may make outbound requests to.
OUTBOUND_HTTP_ALLOWLIST=

# Origins trusted for CSRF (used behind a proxy / different host). Comma-separated.
CSRF_TRUSTED_ORIGINS=
